RewriteEngine on

# Redirect invalid URL
ErrorDocument 400 /attepihamaki/assets/html/400.html
ErrorDocument 401 /attepihamaki/assets/html/401.html
ErrorDocument 403 /attepihamaki/assets/html/403.html
ErrorDocument 404 /attepihamaki/assets/html/404.html
ErrorDocument 500 /attepihamaki/assets/html/500.html
